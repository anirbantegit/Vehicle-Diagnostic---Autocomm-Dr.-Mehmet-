APP_ENV=development

# Bridge Server: exposed to LAN/mobile app
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8090
# Optional override used in QR payload when the PC has multiple LAN adapters.
BRIDGE_PUBLIC_HOST=

# Desktop Agent: localhost only, used for pywinauto automation
AGENT_HOST=127.0.0.1
AGENT_PORT=8091

# Dev token only. Production installer must generate a unique token.
API_TOKEN=change-me-dev-token

# Optional.
# Development empty = ./storage.
# Production recommended = C:\ProgramData\AutocomBridge.
AUTOCOM_BRIDGE_DATA_DIR=

# Autocom local backend discovered from Angular frontend
AUTOCOM_HOST=localhost
AUTOCOM_HTTP_PORT=9000
AUTOCOM_SIGNALR_PORT=9001

# Autocom visible desktop window
WINDOW_TITLE_RE='^Autocom (Cars|Trucks) CDP\+.*$'

# Generic OBD left-sidebar icon fallback click point.
# Calibrated on Autocom Cars CDP+ Release 2021 full-screen layout.
GENERIC_OBD_CLICK_X=52
GENERIC_OBD_CLICK_Y=280

DEFAULT_TIMEOUT=10
DEFAULT_WAIT_AFTER_CLICK=2

DEBUG_SCREENSHOTS=false